# Example backend environment file for Minimalist Launcher
# Copy this to backend/.env and fill in real values for your environment.

NODE_ENV=development
PORT=5000
HOST=127.0.0.1

MONGODB_URI=mongodb://localhost:27017/
DB_NAME=minimalist-launcher-dev

JWT_SECRET=my secret key
JWT_EXPIRY=7d

CORS_ORIGIN=http://localhost:8080

API_RATE_LIMIT=100
API_RATE_WINDOW=15m
TRUST_PROXY=false

# Bug report settings
BUG_REPORT_EMAIL=your-support@yourdomain.com
BUG_REPORT_LOG_FILE=backend/bug-reports.log

OTA_DOWNLOAD_URL=https://github.com/yourusername/monophone/releases/download
LOG_LEVEL=debug
